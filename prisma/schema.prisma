generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Auth.js required tables ──────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // hashed; only for Credentials provider
  isDemo        Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  analyses  Analysis[]
  reports   Report[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Application tables ───────────────────────────────────────────

model Analysis {
  id               String         @id @default(cuid())
  userId           String
  clientName       String
  weekLabel        String
  rawConversation  String         @db.Text
  llmProvider      String
  promptVersion    String
  llmOutputRaw     String         @db.Text
  status           AnalysisStatus @default(PROCESSING)
  tokensUsed       Int?
  latencyMs        Int?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user   User    @relation(fields: [userId], references: [id])
  report Report?
}

model Report {
  id         String       @id @default(cuid())
  analysisId String       @unique
  userId     String
  clientName String
  weekLabel  String
  status     ReportStatus @default(PENDING)
  sections   Json
  coachNotes String?      @db.Text
  approvedAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  analysis Analysis @relation(fields: [analysisId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
}

enum AnalysisStatus {
  PROCESSING
  COMPLETE
  FAILED
}

enum ReportStatus {
  PENDING
  APPROVED
  EDITED
  REJECTED
}